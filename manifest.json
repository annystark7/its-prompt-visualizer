{
  "manifest_version": 3,
  "name": "PromptDeck",
  "version": "1.0.0",
  "description": "A prompt-building overlay for ChatGPT. Structure, organize, and merge prompts directly into the chat.",
  "icons": {
    "16": "icons/128.png",
    "48": "icons/128.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/128.png",
      "48": "icons/128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}